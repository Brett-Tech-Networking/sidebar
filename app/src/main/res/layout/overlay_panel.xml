<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panelContainer"
    android:layout_width="220dp"
    android:layout_height="520dp"
    android:orientation="vertical"
    android:background="@drawable/sidebar_bg"
    android:paddingStart="10dp"
    android:paddingTop="14dp"
    android:paddingEnd="10dp"
    android:paddingBottom="10dp"
    android:elevation="8dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sidebarRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:overScrollMode="never" />

    <LinearLayout
        android:id="@+id/panelFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp">

        <ImageButton
            android:id="@+id/btnAddApps"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/add_apps"
            android:src="@drawable/ic_apps_grid"
            app:tint="@color/edge_panel_muted" />

        <TextView
            android:id="@+id/panelFooterDots"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="• •"
            android:textColor="@color/edge_panel_muted"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btnEditApps"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit_apps"
            android:src="@drawable/ic_edit_small"
            app:tint="@color/edge_panel_muted" />
    </LinearLayout>
</LinearLayout>