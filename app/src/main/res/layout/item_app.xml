<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/appItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingTop="8dp"
    android:paddingEnd="6dp"
    android:paddingBottom="8dp"
    android:background="?android:attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp">

        <ImageView
            android:id="@+id/appIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:background="@drawable/edge_icon_bg"
            android:padding="8dp"
            android:contentDescription="@string/app_icon" />

        <ImageButton
            android:id="@+id/btnRemove"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="1dp"
            android:layout_marginTop="1dp"
            android:background="@drawable/remove_badge_bg"
            android:contentDescription="@string/remove_app"
            android:padding="2dp"
            android:src="@drawable/ic_minus_small"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/appLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:textColor="@color/edge_panel_label"
        android:textSize="11sp" />
</LinearLayout>
