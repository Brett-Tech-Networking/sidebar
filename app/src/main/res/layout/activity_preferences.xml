<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootPreferences"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchEnable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enable_sidebar"
        android:checked="true" />

    <RadioGroup
        android:id="@+id/radioSideGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/radioSideLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:text="@string/side_left" />

        <RadioButton
            android:id="@+id/radioSideRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/side_right" />
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/panel_style"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/radioThemeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/radioThemeDark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:text="@string/theme_dark" />

        <RadioButton
            android:id="@+id/radioThemeLight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:text="@string/theme_light" />

        <RadioButton
            android:id="@+id/radioThemeBlue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_blue" />

        <RadioButton
            android:id="@+id/radioThemeCustom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="@string/theme_custom" />
    </RadioGroup>

    <LinearLayout
        android:id="@+id/customColorRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <View
            android:id="@+id/viewCustomColorPreview"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/handle_bg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooseCustomColor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/choose_custom_color" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/panel_size"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/panel_size_hint"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvWidthValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/panel_width_dp" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderPanelWidth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/tvHeightValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/panel_height_dp" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderPanelHeight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnResetHandleSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/reset_handle_size" />

</LinearLayout>