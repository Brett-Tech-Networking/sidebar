<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlayRow"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <FrameLayout
        android:id="@+id/edgeTouchZone"
        android:layout_width="30dp"
        android:layout_height="110dp"
        android:clickable="true"
        android:focusable="true"
        android:foregroundGravity="center">

        <View
            android:id="@+id/edgeHandle"
            android:layout_width="14dp"
            android:layout_height="78dp"
            android:layout_gravity="center"
            android:background="@drawable/handle_bg"
            android:contentDescription="@string/open_sidebar" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/panelContainer"
        android:layout_width="220dp"
        android:layout_height="520dp"
        android:orientation="vertical"
        android:background="@drawable/sidebar_bg"
        android:paddingStart="10dp"
        android:paddingTop="14dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:layout_marginStart="7dp"
        android:layout_marginEnd="7dp"
        android:elevation="8dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sidebarRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:overScrollMode="never" />

        <LinearLayout
            android:id="@+id/panelFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="6dp">

            <ImageButton
                android:id="@+id/btnAddApps"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/add_apps"
                android:src="@drawable/ic_apps_grid"
                app:tint="@color/edge_panel_muted" />

            <TextView
                android:id="@+id/panelFooterDots"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="• •"
                android:textColor="@color/edge_panel_muted"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnEditApps"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/edit_apps"
                android:src="@drawable/ic_edit_small"
                app:tint="@color/edge_panel_muted" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
